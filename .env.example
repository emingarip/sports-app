# Supabase Configuration
# Rename this file to .env and place your actual Supabase keys below.
# DO NOT COMMIT your actual .env file to version control.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJh......your_anon_key

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Customer Support
CRISP_WEBSITE_ID=your_crisp_website_id
SUPPORT_EMAIL=support@yourdomain.com
WHATSAPP_URL=https://wa.me/yournumber
TELEGRAM_URL=https://t.me/yourusername
INSTAGRAM_URL=https://instagram.com/yourusername
